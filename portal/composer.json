{
    "name": "my-tools/portal",
    "description": "Personal tools workstation portal",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "slim/slim": "~4.13.0",
        "slim/psr7": "~1.6.0",
        "symfony/yaml": "^7.0",
        "symfony/process": "^7.0",
        "predis/predis": "^2.2"
    },
    "repositories": [
        {
            "packagist.org": false
        },
        {
            "type": "composer",
            "url": "https://repo.packagist.org"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Portal\\": "src/",
            "Shared\\": "../shared/"
        }
    }
}
